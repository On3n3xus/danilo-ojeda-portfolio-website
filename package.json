{
  "name": "danilo-ojeda-portfolio-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "qa": "node qa-flight.mjs",
    "test:contact": "node --test tests/contact-api.test.mjs",
    "check:links": "node scripts/check-external-links.mjs",
    "verify": "npm run lint && npm run build && npm run test:contact && npm run test:a11y",
    "test:a11y": "node --test tests/markup-accessibility.test.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/three": "^0.185.0",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
